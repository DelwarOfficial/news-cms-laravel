/storage/*.key
/storage/framework/*
/storage/logs/*
/storage/app/public/*
!/storage/app/public/.gitkeep
!/storage/app/public/.gitignore
/storage/app/reports/

# Public runtime links/uploads
/public/hot
/public/storage
/public/uploads/
/public/media/
/public/news/
/public/temp/

# Build output
/public/build/
/dist/
/build/

# Local databases / test artifacts
*.sqlite
*.sqlite-journal
*.sqlite-shm
*.sqlite-wal
.phpunit.result.cache

# Logs and package manager noise
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

