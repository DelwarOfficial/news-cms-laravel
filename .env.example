APP_NAME=NewsCore
APP_ENV=local
APP_KEY=
APP_DEBUG=false
APP_TIMEZONE=Asia/Dhaka
APP_URL=http://localhost

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=dhaka_magazine
DB_USERNAME=root
DB_PASSWORD=

# Testing (recommended)
# Create this database and grant privileges for your DB user.
DB_TEST_DATABASE=dhaka_magazine_test

SESSION_DRIVER=redis
SESSION_COOKIE=dhaka_magazine_backend_session
SESSION_PATH=/dhaka-magazine
CACHE_STORE=redis
HOMEPAGE_CACHE_TTL=600
QUEUE_CONNECTION=redis
SANCTUM_TOKEN_EXPIRATION=1440
REDIS_CLIENT=predis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_DB=0
REDIS_PREFIX=
REDIS_CACHE_DB=1

FRONTEND_URL=http://dhaka-magazine.test
CMS_URL=http://dhaka-magazine.test/admin

MAIL_MAILER=log

TRANSLATOR_PROVIDER=deepseek
TRANSLATOR_TIMEOUT=60
TRANSLATOR_TEMPERATURE=0.3
TRANSLATOR_MAX_TOKENS=8192
AI_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
DEEPSEEK_API_KEY=

# Spatie Permission
PERMISSION_CACHE_EXPIRATION_TIME=1440

# Multi-Tenancy
TENANCY_ENABLED=false
CENTRAL_DOMAIN=dhaka-magazine.test
TENANCY_SUBDOMAIN_PATTERN=*.dhaka-magazine.test
TENANCY_QUEUE_PREFIX=true
TENANCY_MEDIA_PATH=tenants/%s/media

# Monitoring
REQUEST_ID_HEADER=X-Request-Id
HEALTHCHECK_TOKEN=

# Seeders
SEED_DEMO_DATA=false
